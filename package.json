    "dotenv": "^16",
    "drizzle-orm": "^0.32",
    "fastify": "^4",
    "ioredis": "^5",
    "postgres": "^3",
    "@elastic/elasticsearch": "^8",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/bcrypt": "^5",
    "@types/node": "^20",
    "drizzle-kit": "^0.23",
    "tsx": "^4",
