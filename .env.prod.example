# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=bakala
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ── Application ───────────────────────────────────────────────────────────────
DATABASE_URL=postgres://bakala:CHANGE_ME_strong_password_here@postgres:5432/bakala
REDIS_URL=redis://:CHANGE_ME_redis_password_here@redis:6379
REDIS_PASSWORD=CHANGE_ME_redis_password_here
ELASTICSEARCH_URL=http://elasticsearch:9200

# Public URL of your domain (no trailing slash) — used for CORS
FRONTEND_URL=https://yourdomain.com

# Minimum 32 random chars — generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_64_char_minimum_secret

PORT=3000
TRACKING_PORT=3001
DISCOVERY_PORT=3002
NODE_ENV=production
